# Copy to .env and fill values locally (do not commit real secrets)
STEP_CA_PASSWORD=replace-me
STEPCA_INIT_NAME=HomeLab
STEPCA_INIT_DNS_NAMES=step-ca,localhost
STEPCA_INIT_ADDRESS=:9000
STEPCA_INIT_PROVISIONER_NAME=admin
STEP_CA_PORT=9000

# host IP used to bind metrics port mapping (optional)
HOST_IP=127.0.0.1
